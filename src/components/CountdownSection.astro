---
interface HeroData {
  nombreNovia: string;
  nombreNovio: string;
  fecha: string;
  lugar: string;
}

const { nombreNovia, nombreNovio, fecha, lugar } = Astro.props as HeroData;

// Fecha formateada para mostrar en horario de México
const fechaMX = fecha
  ? new Date(fecha).toLocaleString("es-MX", {
      timeZone: "America/Mexico_City",
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "2-digit",
      minute: "2-digit",
    })
  : "";

// Usar la fecha que llega del API como objetivo del contador
const targetDate = fecha || "";
const units = [
  { label: "Días", id: "dias" },
  { label: "Horas", id: "horas" },
  { label: "Min", id: "min" },
  { label: "Seg", id: "seg" },
];
---

<section class="py-16 px-6">
  <div class="flex justify-center gap-4 md:gap-6 animate-fade-up">
    {units.map((unit) => (
      <div class="flex flex-col items-center bg-card rounded-lg p-4 min-w-[70px] shadow-sm border border-border">
        <span
          id={`countdown-${unit.id}`}
          class="font-display text-3xl md:text-4xl font-bold text-primary"
        >
          00
        </span>
        <span class="font-body text-[10px] tracking-[0.15em] uppercase text-muted-foreground mt-1">
          {unit.label}
        </span>
      </div>
    ))}
  </div>

  {fechaMX && (
    <p class="text-center mt-4 text-sm text-muted-foreground">
      {fechaMX}
    </p>
  )}
</section>

<script define:vars={{ targetDate }}>
  function update() {
    if (!targetDate) return;

    const target = new Date(targetDate).getTime();

    if (Number.isNaN(target)) {
      console.error("Fecha inválida:", targetDate);
      return;
    }

    const diff = target - Date.now();

    const d = diff > 0 ? Math.floor(diff / 86400000) : 0;
    const h = diff > 0 ? Math.floor((diff / 3600000) % 24) : 0;
    const m = diff > 0 ? Math.floor((diff / 60000) % 60) : 0;
    const s = diff > 0 ? Math.floor((diff / 1000) % 60) : 0;

    const pad = (n) => String(n).padStart(2, "0");

    const diasEl = document.getElementById("countdown-dias");
    const horasEl = document.getElementById("countdown-horas");
    const minEl = document.getElementById("countdown-min");
    const segEl = document.getElementById("countdown-seg");

    if (diasEl) diasEl.textContent = pad(d);
    if (horasEl) horasEl.textContent = pad(h);
    if (minEl) minEl.textContent = pad(m);
    if (segEl) segEl.textContent = pad(s);
  }

  update();
  setInterval(update, 1000);
</script>

<style>
  .animate-fade-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.8s ease forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>