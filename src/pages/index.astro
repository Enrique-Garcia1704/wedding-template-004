---
import Layout from '../layouts/Layout.astro';

import HeroSection from '../components/HeroSection.astro';
import CountdownSection from '../components/CountdownSection.astro';
import DetailsSection from '../components/DetailsSection.astro';
import FooterSection from '../components/FooterSection.astro';
import GiftSection from '../components/GiftSection.astro';
import RSVPSection from '../components/RSVPSection.astro';
import LocationSection from '../components/LocationSection.astro';
import TimelineSection from '../components/TimelineSection.astro';




import { fetchIndexData } from '../lib/services/index.ts';

export const prerender = false;

const id = Astro.url.searchParams.get("id");
const indexData = id ? await fetchIndexData(id) : null;


indexData?.detalle_evento?.[0]?.nombre_pareja1
indexData?.fecha_evento

---

<Layout>
	<HeroSection  nombreNovia={indexData?.detalle_evento?.[0]?.nombre_pareja1} nombreNovio={indexData?.detalle_evento?.[0]?.nombre_pareja2} />
	<CountdownSection fecha={indexData?.fecha_evento} />
	<TimelineSection />
	<DetailsSection fecha={indexData?.fecha_evento} lugar={indexData?.detalle_evento?.[0]?.lugar} />
	<LocationSection lugar={indexData?.detalle_evento?.[0]?.lugar} />
	<GiftSection />
	<RSVPSection />
	<FooterSection nombreNovia={indexData?.detalle_evento?.[0]?.nombre_pareja1} nombreNovio={indexData?.detalle_evento?.[0]?.nombre_pareja2} />
</Layout>
